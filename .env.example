# Frontend public config
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_LLM_PROXY_URL=/api/llm/chat
# Set to true for local SaaS UI testing without Supabase/Vercel.
VITE_SAAS_MOCK=false

# Local-only fallback. Do not use these in a public website build.
VITE_LLM_BASE_URL=
VITE_LLM_API_KEY=
VITE_LLM_MODEL=gpt-5.5
VITE_LLM_FAST_MODEL=gpt-5.5
VITE_LLM_DEEP_MODEL=gpt-5.5

# Server-only config for future API routes. Do not prefix these with VITE_.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LLM_BASE_URL=
LLM_PROXY_URL=
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_FAST_MODEL=gpt-5.5
LLM_DEEP_MODEL=gpt-5.5
