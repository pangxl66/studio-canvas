function findStoryboardShotListChild(
  nodes: StudioRFNode[],
  edges: Edge[],
  storyboardNodeId: string,
): StudioRFNode | null {
  const edge = edges.find(
    (e) => e.source === storyboardNodeId && e.sourceHandle === SHOT_LIST_LINK_HANDLE_ID,
  );
  if (!edge) return null;
  return (
    nodes.find(
      (n) => n.id === edge.target && n.type === 'shotList' && n.data.type === 'shot_list_node',
    ) ?? null
  );
}

