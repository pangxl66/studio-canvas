# Public browser config. These are safe to expose.
VITE_SAAS_MOCK=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_LLM_PROXY_URL=/api/llm/chat
VITE_ADMIN_TOOLS=false

# Hong Kong VPS users can set VITE_SUPABASE_URL=/supabase to avoid browser-side
# network failures when direct access to *.supabase.co is unstable.

# Server-only config. Add these only in the hosting environment or server .env file.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_FAST_MODEL=gpt-5.5
LLM_DEEP_MODEL=gpt-5.5

# Optional provider-specific server config for the top-right API switch.
# If these are empty, the server falls back to the legacy LLM_* values above.
GPT_LLM_BASE_URL=https://api.openai.com/v1
GPT_LLM_API_KEY=
GPT_LLM_MODEL=gpt-5.5
GPT_LLM_FAST_MODEL=gpt-5.5
GPT_LLM_DEEP_MODEL=gpt-5.5
DEEPSEEK_LLM_BASE_URL=https://api.deepseek.com
DEEPSEEK_LLM_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-chat
DEEPSEEK_LLM_FAST_MODEL=deepseek-chat
DEEPSEEK_LLM_DEEP_MODEL=deepseek-chat

# Temporary test login. Separate multiple invite codes with commas.
TEST_INVITE_CODES=
TEST_INVITE_SECRET=
TEST_INVITE_MONTHLY_QUOTA=30

# Do not use these in production:
# VITE_LLM_API_KEY
# VITE_LLM_BASE_URL
