# Public browser config. These are safe to expose.
VITE_SAAS_MOCK=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_LLM_PROXY_URL=/api/llm/chat
VITE_ADMIN_TOOLS=false

# Hong Kong VPS users can set VITE_SUPABASE_URL=/supabase to avoid browser-side
# network failures when direct access to *.supabase.co is unstable.

# Server-only config. Add these only in the hosting environment or server .env file.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_FAST_MODEL=gpt-5.5
LLM_DEEP_MODEL=gpt-5.5

# Do not use these in production:
# VITE_LLM_API_KEY
# VITE_LLM_BASE_URL
